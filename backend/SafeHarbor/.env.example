# SafeHarbor backend secret bootstrap (non-secret defaults + placeholders)
# Copy to `.env` for local use, or set these values in user-secrets/Azure Key Vault.

# ASP.NET environment
ASPNETCORE_ENVIRONMENT=Development

# Database (use a real password locally; never commit it)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=SafeHarborDB;Username=postgres;Password=CHANGE_ME

# JWT auth settings (used by backend token issuance/validation)
LocalAuth__Enabled=true
Jwt__Issuer=safeharbor-local
Jwt__Audience=safeharbor-local-client
Jwt__SigningKey=CHANGE_ME_MIN_32_CHARS

# Optional: Key Vault URI for deployed environments
KeyVault__VaultUri=

# Optional telemetry override
Telemetry__OtlpEndpoint=
