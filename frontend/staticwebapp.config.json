{
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "*.js",
      "*.mjs",
      "*.css",
      "*.png",
      "*.jpg",
      "*.svg",
      "*.ico",
      "*.json"
    ]
  }
}
