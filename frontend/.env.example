# Optional local-only helper for role simulation in non-auth development scenarios.
VITE_ENABLE_DEV_ROLE_SIMULATION=true

# Optional API base; point to local backend when frontend runs on :5173.
# Prefer the HTTPS backend URL to avoid browser CORS issues caused by HTTP->HTTPS redirects.
# Keep this aligned with backend/SafeHarbor/SafeHarbor/Properties/launchSettings.json.
VITE_API_BASE_URL=https://localhost:7217

# Frontend now always uses backend JWT + users-table auth flow.
# Keep auth mode fixed to avoid Entra/AzureAD runtime assumptions.
VITE_AUTH_MODE=local
